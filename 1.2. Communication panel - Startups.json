    {
      "parameters": {
        "sendTo": "={{ $('Get emails to send reminders').item.json.Email }}",
        "subject": "=Final details for your pitch with {{ $('Aggregate variables values').item.json.data[2].VALUE }}",
        "message": "=Dear {{ $('Get emails to send reminders').item.json.Name }},<br><br>\n\nWe’re looking forward to your pitch at tomorrow’s {{ $('Aggregate variables values').item.json.data[2].VALUE }} Investment Committee. Here’s a quick reminder of the essential details:<br><br>\n\n<b>Day:</b> {{ $('Aggregate variables values').item.json.data[3].VALUE }}<br>\n<b>Time:</b> {{ $('Aggregate variables values').item.json.data[4].VALUE }}. Your pitch starting at {{ $('Route right message').item.json['Time of pitching'] }}<br>\n<b>Location:</b> {{ $('Aggregate variables values').item.json.data[5].VALUE }}<br><br>\n<b>Format:</b> 15-minute pitch + 30-minute Q&A<br><br>\n\nPlease join 15 minutes early to ensure everything runs smoothly.<br><br>\n\nAlso, if you still want to change anything in your slides, make sure to send us the final slides before the event.<br><br>\n\nBest of luck and speak tomorrow,<br>\n<i>Sarah</i>",
        "options": {
          "appendAttribution": false
        }
      },
